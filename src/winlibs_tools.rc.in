#include <winver.h>
#include <winuser.h>
#include "winlibs_common.h"

1 RT_MANIFEST winlibs_tools.manifest

1 VERSIONINFO
  PRODUCTVERSION WINLIBS_VERSION_MAJOR,WINLIBS_VERSION_MINOR,WINLIBS_VERSION_MICRO
  FILEVERSION WINLIBS_VERSION_MAJOR,WINLIBS_VERSION_MINOR,WINLIBS_VERSION_MICRO,0
  FILETYPE VFT_APP
  {
    BLOCK "StringFileInfo"
    {
      BLOCK "040904B0"
      {
        VALUE "ProductName", "winlibs_tools"
        VALUE "CompanyName", "winlibs.com"
        VALUE "LegalCopyright", "GNU General Public License"
        VALUE "FileDescription", "winlibs_tools, part of winlibs_tools"
        VALUE "InternalName", "winlibs_tools"
        VALUE "OriginalFilename", "winlibs_tools.exe"
        //VALUE "ProductVersion", "0.0.0"
        //VALUE "FileVersion", "0.0.0.0"
      }
    }
    
    BLOCK "VarFileInfo"
    {
      VALUE "Translation", 0x0409, 0x04B0
    }
  }
