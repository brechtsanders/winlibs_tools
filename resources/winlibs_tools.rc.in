#include <winver.h>
#include <winuser.h>
#include "winlibs_common.h"

1 RT_MANIFEST "../resources/winlibs_tools.manifest"

1 VERSIONINFO
  PRODUCTVERSION WINLIBS_VERSION_MAJOR,WINLIBS_VERSION_MINOR,WINLIBS_VERSION_MICRO
  FILEVERSION WINLIBS_VERSION_MAJOR,WINLIBS_VERSION_MINOR,WINLIBS_VERSION_MICRO,0
  FILETYPE VFT_APP
  {
    BLOCK "StringFileInfo"
    {
      BLOCK "040904B0"
      {
        VALUE "ProductName", "%PRODUCTNAME%"
        VALUE "CompanyName", "winlibs.com"
        VALUE "LegalCopyright", "GNU General Public License"
        VALUE "FileDescription", "%PRODUCTNAME%, part of winlibs_tools"
        VALUE "InternalName", "%PRODUCTNAME%"
        VALUE "OriginalFilename", "%PRODUCTNAME%.exe"
        VALUE "ProductVersion", "%PRODUCTVERSION%"
        VALUE "FileVersion", "%PRODUCTVERSION%.0"
      }
    }
    
    BLOCK "VarFileInfo"
    {
      VALUE "Translation", 0x0409, 0x04B0
    }
  }

1 ICON "../resources/winlibs_logo.ico"

